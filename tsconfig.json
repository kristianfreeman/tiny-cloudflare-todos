{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "@cloudflare/workers-types",
      "node"
    ],
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/**/*.ts",
    "ui/**/*.ts",
    "ui/**/*.tsx",
    "drizzle/**/*.ts",
    "drizzle.config.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vite.config.ts"
  ]
}

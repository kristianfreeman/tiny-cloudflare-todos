{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "@cloudflare/workers-types",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "shiro": [
        "packages/shiro/src/index.ts"
      ],
      "shiro/styles.css": [
        "packages/shiro/src/styles.css"
      ]
    },
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/**/*.ts",
    "packages/shiro/**/*.ts",
    "packages/shiro/**/*.tsx",
    "ui/**/*.ts",
    "ui/**/*.tsx",
    "drizzle/**/*.ts",
    "drizzle.config.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vite.config.ts"
  ]
}
